{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chaeboxi",
  "version": "0.1.0",
  "identifier": "com.chaeboxi",
  "build": {
    "beforeDevCommand": "pnpm --filter chaeboxi-svelte dev",
    "beforeBuildCommand": "pnpm --filter chaeboxi-svelte build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../src-svelte/build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Chaeboxi",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 600,
        "resizable": true,
        "maximized": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
